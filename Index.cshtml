@{
    ViewData["Title"] = "Home";
}

<div class="text-center">
    <h1 class="display-4">Welcome to My Website</h1>
    <p class="lead">My name is David Fontenot Jr.</p>

    <!-- Picture -->
    <img src="~/images/mypic.jpg" class="img-fluid rounded mb-3" alt="My Picture" width="250" />

    <!-- Buttons -->
    <div class="mt-3">
        <a asp-controller="Home" asp-action="About" class="btn btn-primary me-2">About Me</a>
        <a asp-controller="Home" asp-action="Hobbies" class="btn btn-success me-2">Hobbies</a>
        <!-- Static file link for resume -->
        <a asp-controller="Home" asp-action="GetResume" class="btn btn-dark">Resume</a>
    </div>

    <!-- Contact Info -->
    <p class="mt-3">
        Instagram: <a href="https://www.instagram.com/davidfontenot_/" target="_blank">&#64;davidfontenot_</a>
    </p>
    </p>
    </p>
    </p>

    <!-- Table -->
    <h3 class="mt-4">Quick Facts</h3>
    <table class="table table-bordered table-striped">
        <thead>
            <tr>
                <th>Category</th>
                <th>Detail</th>
            </tr>
        </thead>
        <tbody>
            <tr>
                <td>Favorite Food</td>
                <td>Buffalo Wings</td>
            </tr>
            <tr>
                <td>Favorite Movie</td>
                <td>Game Plan</td>
            </tr>
            <tr>
                <td>Study Habit</td>
                <td>Listening to music</td>
            </tr>
        </tbody>
    </table>

    <!-- TED Talk -->
    <h3 class="mt-4">My Favorite TED Talk</h3>
    <div class="ratio ratio-16x9">
        <iframe src="https://embed.ted.com/talks/paul_triple_h_levesque_patrick_talty_inside_wwe_s_storytelling_machine"
                width="560" height="315" frameborder="0" allowfullscreen>
        </iframe>
    </div>
</div>
